{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://siorb.dev/schemas/catalog/policy-v1.json",
  "title": "Siorb PolicyFile v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "id", "allow_packages", "deny_packages", "allow_categories", "deny_categories",
    "allow_sources", "deny_sources", "allow_backends", "deny_backends", "allow_channels", "deny_channels",
    "allow_scopes", "deny_scopes", "allow_licenses", "deny_licenses", "preferred_backends",
    "require_signatures", "require_digests", "trusted_publishers", "forbid_artifacts", "forbid_prerelease",
    "require_confirmation", "require_dry_run", "network_domains", "prevent_downgrade", "prevent_uninstall"
  ],
  "properties": {
    "schema_version": { "enum": ["1", "1.0"] },
    "id": { "$ref": "#/$defs/id" },
    "allow_packages": { "$ref": "#/$defs/ids" },
    "deny_packages": { "$ref": "#/$defs/ids" },
    "allow_categories": { "$ref": "#/$defs/ids" },
    "deny_categories": { "$ref": "#/$defs/ids" },
    "allow_sources": { "$ref": "#/$defs/ids" },
    "deny_sources": { "$ref": "#/$defs/ids" },
    "allow_backends": { "$ref": "#/$defs/backends" },
    "deny_backends": { "$ref": "#/$defs/backends" },
    "allow_channels": { "$ref": "#/$defs/channels" },
    "deny_channels": { "$ref": "#/$defs/channels" },
    "allow_scopes": { "$ref": "#/$defs/scopes" },
    "deny_scopes": { "$ref": "#/$defs/scopes" },
    "allow_licenses": { "$ref": "#/$defs/strings" },
    "deny_licenses": { "$ref": "#/$defs/strings" },
    "preferred_backends": { "$ref": "#/$defs/backends" },
    "require_signatures": { "type": "boolean" },
    "require_digests": { "type": "boolean" },
    "trusted_publishers": { "$ref": "#/$defs/strings" },
    "minimum_provenance": { "type": "string", "minLength": 1 },
    "forbid_artifacts": { "type": "boolean" },
    "forbid_prerelease": { "type": "boolean" },
    "require_confirmation": { "type": "boolean" },
    "require_dry_run": { "type": "boolean" },
    "network_domains": { "type": "array", "uniqueItems": true, "items": { "type": "string", "format": "hostname" } },
    "prevent_downgrade": { "type": "boolean" },
    "prevent_uninstall": { "type": "boolean" },
    "allow_self_update": { "type": "boolean" },
    "freshness_days": { "type": "integer", "minimum": 1 }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "ids": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/id" } },
    "strings": { "type": "array", "uniqueItems": true, "items": { "type": "string" } },
    "backends": { "type": "array", "uniqueItems": true, "items": { "enum": ["winget", "scoop", "chocolatey", "homebrew-formula", "homebrew-cask", "macports", "apt", "dnf", "pacman", "zypper", "apk", "flatpak", "snap", "artifact"] } },
    "channels": { "type": "array", "uniqueItems": true, "items": { "enum": ["stable", "beta", "nightly", "custom"] } },
    "scopes": { "type": "array", "uniqueItems": true, "items": { "enum": ["user", "system", "auto"] } }
  }
}
