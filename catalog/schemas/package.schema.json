{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://siorb.dev/schemas/catalog/package-v1.json",
  "title": "Siorb package manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "id", "name", "description", "aliases", "deprecated_aliases", "search_terms",
    "homepage", "upstream", "license", "categories", "capabilities", "risk", "channels", "conflicts",
    "replacements", "dependencies", "optional_relationships", "version_normalization", "verification",
    "evidence", "reviewed_at", "deprecated", "maintainers", "sources"
  ],
  "properties": {
    "schema_version": { "const": "1" },
    "id": { "$ref": "#/$defs/id" },
    "name": { "type": "string", "minLength": 1, "maxLength": 80 },
    "description": { "type": "string", "minLength": 20, "maxLength": 180 },
    "aliases": { "$ref": "#/$defs/ids" },
    "deprecated_aliases": { "$ref": "#/$defs/ids" },
    "search_terms": { "$ref": "#/$defs/strings" },
    "homepage": { "type": "string", "format": "uri", "pattern": "^https://" },
    "upstream": { "type": "string", "minLength": 1 },
    "license": { "type": "string", "minLength": 1 },
    "categories": { "$ref": "#/$defs/nonEmptyIds" },
    "capabilities": { "$ref": "#/$defs/nonEmptyIds" },
    "risk": { "enum": ["standard", "elevated", "restricted"] },
    "channels": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/channel" } },
    "conflicts": { "$ref": "#/$defs/ids" },
    "replacements": { "$ref": "#/$defs/ids" },
    "dependencies": { "$ref": "#/$defs/ids" },
    "optional_relationships": { "$ref": "#/$defs/ids" },
    "version_normalization": { "enum": ["semver", "semver-loose", "backend-native", "date"] },
    "verification": { "enum": ["backend-signature", "sandbox-signature", "digest-and-publisher"] },
    "evidence": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "format": "uri", "pattern": "^https://" } },
    "reviewed_at": { "$ref": "#/$defs/date" },
    "deprecated": { "type": "boolean" },
    "maintainers": { "$ref": "#/$defs/nonEmptyStrings" },
    "sources": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/source" } }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9]*(?:-[a-z0-9]+)*$" },
    "ids": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/id" } },
    "nonEmptyIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/id" } },
    "strings": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "nonEmptyStrings": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "date": { "type": "string", "format": "date" },
    "channel": { "enum": ["stable", "beta", "nightly", "custom"] },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "platform", "backend", "package_id", "trust", "scope", "channel", "architectures", "priority", "requires_privilege", "provenance", "evidence", "reviewed_at"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "platform": { "enum": ["windows", "macos", "debian", "fedora", "arch", "opensuse", "alpine", "linux"] },
        "distributions": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "backend": { "enum": ["winget", "scoop", "chocolatey", "homebrew-formula", "homebrew-cask", "macports", "apt", "dnf", "pacman", "zypper", "apk", "flatpak", "snap", "artifact"] },
        "package_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._@/+:-]*$" },
        "trust": { "enum": ["native", "sandboxed", "verified-upstream"] },
        "scope": { "enum": ["user", "system", "auto"] },
        "channel": { "$ref": "#/$defs/channel" },
        "architectures": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "enum": ["x86_64", "aarch64"] } },
        "priority": { "type": "integer", "minimum": 0, "maximum": 1000 },
        "requires_privilege": { "type": "boolean" },
        "provenance": { "enum": ["backend-repository", "signed-upstream-metadata"] },
        "evidence": { "type": "string", "format": "uri", "pattern": "^https://" },
        "reviewed_at": { "$ref": "#/$defs/date" },
        "verification": { "$ref": "#/$defs/artifactVerification" }
      },
      "allOf": [
        {
          "if": { "required": ["backend"], "properties": { "backend": { "const": "artifact" } } },
          "then": { "required": ["verification"] }
        }
      ]
    },
    "artifactVerification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sha256", "content_type", "max_bytes", "kind", "format"],
      "properties": {
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "signer": { "type": "string", "minLength": 1, "maxLength": 256 },
        "content_type": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9!#$&^_.+-]*/[A-Za-z0-9][A-Za-z0-9!#$&^_.+-]*$" },
        "max_bytes": { "type": "integer", "minimum": 1, "maximum": 17179869184 },
        "kind": { "enum": ["portable-archive", "portable-executable", "native-installer"] },
        "format": { "enum": ["zip", "tar", "tar.gz", "msi", "msix", "exe", "pkg", "dmg", "deb", "rpm", "appimage"] },
        "archive_format": { "enum": ["zip", "tar", "tar.gz"] },
        "payload_path": { "type": "string", "minLength": 1, "maxLength": 512, "pattern": "^[A-Za-z0-9+._ -]+(?:/[A-Za-z0-9+._ -]+)*$" },
        "strip_components": { "type": "integer", "minimum": 0, "maximum": 16 },
        "install_arguments": { "type": "array", "maxItems": 4, "uniqueItems": true, "items": { "enum": ["/S", "/silent", "/verysilent", "/quiet", "/norestart", "--silent", "--quiet"] } },
        "allowed_redirect_hosts": { "type": "array", "uniqueItems": true, "items": { "type": "string", "pattern": "^[A-Za-z0-9.-]+$" } }
      },
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "portable-archive" } } },
          "then": {
            "required": ["archive_format"],
            "properties": {
              "format": { "enum": ["zip", "tar", "tar.gz"] },
              "install_arguments": { "maxItems": 0 }
            }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "portable-executable" } } },
          "then": {
            "properties": {
              "format": { "const": "appimage" },
              "install_arguments": { "maxItems": 0 },
              "strip_components": { "const": 0 }
            }
          }
        },
        {
          "if": { "properties": { "format": { "const": "dmg" } } },
          "then": { "required": ["signer", "payload_path"] }
        },
        {
          "if": { "properties": { "format": { "enum": ["msi", "msix", "exe", "pkg"] } } },
          "then": { "required": ["signer"] }
        },
        {
          "if": { "properties": { "format": { "enum": ["msi", "msix", "pkg", "dmg", "deb", "rpm"] } } },
          "then": { "properties": { "install_arguments": { "maxItems": 0 } } }
        }
      ]
    }
  }
}
